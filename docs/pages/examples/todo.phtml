<template data-slot="description">A full todo app with Yesterday/Today view — showing signal, computed, each, model, getItemContext, and localStorage persistence.</template>

<div class="page-intro">
  <h1>Simulation 02<br><span class="sim-subtitle">Todo Mission</span></h1>
  <p>
    A full todo app with a Yesterday/Today view. Demonstrates <code>each</code>, <code>model</code>,
    <code>getItemContext</code>, <code>computed</code> filtering, and <code>effect</code>-based
    localStorage persistence — all without a build step.
  </p>
</div>


<!-- ══════════════════════════════════════════════════════════
     LIVE DEMO
     ══════════════════════════════════════════════════════════ -->
<div class="demo-container">
  <div class="demo-label">Live Telemetry</div>
  <div class="demo">
    <div id="todo-app">
      <div class="app-header">
        <span>Mission Log</span>
        <span text="summary" class="todo-summary"></span>
      </div>

      <!-- View tabs -->
      <div class="todo-tabs">
        <button cls="todayTabCls" onclick="showToday">
          Today <span class="badge" text="activeCount"></span>
        </button>
        <button cls="yesterdayTabCls" onclick="showCompleted">
          Completed <span class="badge" text="completedCount"></span>
        </button>
      </div>

      <!-- Add new (only in today view) -->
      <div class="todo-input-row" show="isToday">
        <input model="newTodo" placeholder="MISSION OBJECTIVE...">
        <button onclick="addTodo">LAUNCH ▶</button>
      </div>

      <!-- List -->
      <ul class="todo-list" each="visibleTodos" key="id">
        <template>
          <li class="todo-item">
            <span class="todo-text" text="text" cls="textCls"></span>
            <div class="todo-actions">
              <button onclick="toggleTodo" text="actionLabel"></button>
              <button onclick="removeTodo" class="danger">ABORT</button>
            </div>
          </li>
        </template>
      </ul>

      <!-- Empty state -->
      <div show="isEmpty">
        <div class="todo-empty" id="empty-msg">— No objectives logged —</div>
      </div>

      <p class="todo-summary" text="summary"></p>
    </div>
  </div>
</div>

<script type="module" src="/assets/todo.js"></script>


