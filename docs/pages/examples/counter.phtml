<div class="page-intro">
  <h1>Simulation 01<br><span class="sim-subtitle">Counter</span></h1>
  <p>The Hello World of reactive UIs. Three signals, two computeds, three handlers. This is all of rdbl in 20 lines.</p>
</div>


<!-- ══════════════════════════════════════════════════════════
     LIVE DEMO
     ══════════════════════════════════════════════════════════ -->
<div class="demo-container">
  <div class="demo-label">Live Telemetry</div>
  <div class="demo">
    <div id="counter-app">
      <div class="counter-display">
        <div class="counter-value" text="count">0</div>
        <div class="counter-label">Mission Count</div>

        <div class="counter-readouts">
          <div>
            <div class="readout-label">Double</div>
            <div class="readout-value" text="double">0</div>
          </div>
          <div>
            <div class="readout-label">Status</div>
            <div class="readout-value" text="status" cls="statusCls">STANDBY</div>
          </div>
          <div>
            <div class="readout-label">History</div>
            <div class="readout-value" text="history">—</div>
          </div>
        </div>

        <div class="counter-controls">
          <button onclick="decrement" class="left">−</button>
          <button onclick="reset" class="ghost">RST</button>
          <button onclick="increment" class="right">+</button>
        </div>
      </div>

      <div class="effect-log-wrap">
        <div class="effect-log-label">Effect log</div>
        <div id="effect-log" class="effect-log"></div>
      </div>
    </div>
  </div>
</div>


