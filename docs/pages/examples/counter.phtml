<div class="tab-group">
  <div class="tab-bar">
    <button class="tab-btn">HTML</button>
    <button class="tab-btn">JavaScript</button>
  </div>

  <div class="tab-pane">
<div class="code-file">counter.html</div>
<pre><code>&lt;div id="counter-app"&gt;

  &lt;!-- Display --&gt;
  &lt;div class="counter-value" <span class="attr">text</span>="<span class="val">count</span>"&gt;&lt;/div&gt;

  &lt;!-- Derived readouts --&gt;
  &lt;div <span class="attr">text</span>="<span class="val">double</span>"&gt;&lt;/div&gt;
  &lt;div <span class="attr">text</span>="<span class="val">status</span>" <span class="attr">cls</span>="<span class="val">statusCls</span>"&gt;&lt;/div&gt;

  &lt;!-- Controls --&gt;
  &lt;button <span class="attr">onclick</span>="<span class="val">decrement</span>"&gt;−&lt;/button&gt;
  &lt;button <span class="attr">onclick</span>="<span class="val">reset</span>"&gt;RST&lt;/button&gt;
  &lt;button <span class="attr">onclick</span>="<span class="val">increment</span>"&gt;+&lt;/button&gt;

&lt;/div&gt;</code></pre>
  </div>

  <div class="tab-pane">
<div class="code-file">counter.js</div>
<pre><code><span class="kw">import</span> { bind, signal, computed, effect } <span class="kw">from</span> <span class="str">'rdbl'</span>

<span class="com">// ── State ──────────────────────────────────────────────</span>
<span class="kw">const</span> count = signal(<span class="num">0</span>)

<span class="com">// ── Derived ────────────────────────────────────────────</span>
<span class="kw">const</span> double    = computed(() =&gt; count() * <span class="num">2</span>)
<span class="kw">const</span> status    = computed(() =&gt;
  count() &gt; <span class="num">0</span> ? <span class="str">'NOMINAL'</span> :
  count() &lt; <span class="num">0</span> ? <span class="str">'ABORT'</span>   : <span class="str">'STANDBY'</span>
)
<span class="kw">const</span> statusCls = computed(() =&gt;
  count() &gt; <span class="num">0</span> ? <span class="str">'readout-value green'</span>  :
  count() &lt; <span class="num">0</span> ? <span class="str">'readout-value red'</span>    :
                 <span class="str">'readout-value amber'</span>
)

<span class="com">// ── Side effect ────────────────────────────────────────</span>
effect(() =&gt; {
  <span class="com">// Re-runs whenever count changes</span>
  console.log(<span class="str">'count changed to'</span>, count())
})

<span class="com">// ── Bind ───────────────────────────────────────────────</span>
bind(document.querySelector(<span class="str">'#counter-app'</span>), {
  count,
  double,
  status,
  statusCls,
  increment: () =&gt; count.set(count() + <span class="num">1</span>),
  decrement: () =&gt; count.set(count() - <span class="num">1</span>),
  reset:     () =&gt; count.set(<span class="num">0</span>),
})</code></pre>
  </div>
</div>

