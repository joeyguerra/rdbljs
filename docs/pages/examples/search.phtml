<div class="code-file">search.js</div>
<pre><code><span class="kw">import</span> { bind, signal, computed } <span class="kw">from</span> <span class="str">'rdbl'</span>

<span class="com">// ── Signals (user inputs) ─────────────────────────────────────</span>
<span class="kw">const</span> query        = signal(<span class="str">''</span>)
<span class="kw">const</span> statusFilter = signal(<span class="str">''</span>)

<span class="com">// ── Computed (derived filtered list) ──────────────────────────</span>
<span class="kw">const</span> results = computed(() =&gt; {
  <span class="kw">const</span> q  = query().toLowerCase().trim()
  <span class="kw">const</span> sf = statusFilter()

  <span class="kw">return</span> MISSIONS.filter(m =&gt; {
    <span class="kw">const</span> matchesQ  = !q  || m.name.toLowerCase().includes(q)
    <span class="kw">const</span> matchesSF = !sf || m.status === sf
    <span class="kw">return</span> matchesQ && matchesSF
  })
})

<span class="kw">const</span> resultCount = computed(() =&gt; results().length)
<span class="kw">const</span> isEmpty     = computed(() =&gt; results().length === <span class="num">0</span>)

<span class="com">// ── Bind ──────────────────────────────────────────────────────</span>
<span class="com">// model= wires inputs to signals (two-way)</span>
<span class="com">// each= renders results (re-renders on every filter change)</span>
bind(document.querySelector(<span class="str">'#search-app'</span>), {
  query, statusFilter,
  results, resultCount, isEmpty,
})</code></pre>
