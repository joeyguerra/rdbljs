        <input model="query" placeholder="SEARCH MISSIONS...">
        <select model="statusFilter" class="filter-select">
          <option value="">ALL STATUS</option>
          <option value="success">SUCCESS</option>
          <option value="partial">PARTIAL</option>
          <option value="failure">FAILURE</option>
        </select>
      </div>

      <!-- Results -->
      <ul class="mission-list" each="results" key="id">
        <template>
          <li class="mission-item">
            <span class="mission-name" text="name"></span>
            <span class="mission-year" text="year"></span>
            <span class="mission-status" text="statusLabel" cls="statusCls"></span>
          </li>
        </template>
      </ul>

      <!-- Empty state -->
      <div show="isEmpty" class="empty-state">
        — No missions match —
      </div>
    </div>
  </div>
